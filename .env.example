# --- Postgres URL (app reads POSTGRES_URL or DATABASE_URL) ---
#
# Easiest on Railway: use the DATABASE_URL variable Railway sets when you add Postgres,
# or copy the “Connect” string from the Postgres service.
#
# Private networking between Railway services (TCP on port 5432). In Variables you can
# build one string from the linked Postgres service (substitution is done by Railway):
#
#   postgresql://${{PGUSER}}:${{POSTGRES_PASSWORD}}@${{RAILWAY_PRIVATE_DOMAIN}}:5432/${{PGDATABASE}}
#
# Local development (npm run dev on your PC): use the PUBLIC Postgres URL from Railway’s
# Postgres → Connect tab (TCP proxy / public hostname). Private hostnames are only reachable
# from inside Railway’s network, not from localhost.
#
# If your password has @, :, /, or other reserved characters, URL-encode it in the
# userinfo part, or use Railway’s pre-built DATABASE_URL.
#
POSTGRES_URL=

# Alternative name (either works):
# DATABASE_URL=

JWT_SECRET=
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Only if the frontend is hosted separately from this Next app
# NEXT_PUBLIC_API_URL=
