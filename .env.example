# --- CRA build (Vercel / Netlify). Set in the host’s Environment Variables UI.
# Public API origin where Express runs (no trailing slash). Required for production UI.
# REACT_APP_API_URL=https://your-api.example.com

# --- Server (.env on the machine running server/index.js, or provider env vars)
# Admin login (server only — never exposed to the React bundle)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Required for signing admin sessions; use a long random value in production
JWT_SECRET=change-this-to-a-long-random-string
